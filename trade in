
<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>舊換新回收建議</title>

<style>
:root {
    --apple-blue: #0071e3;
    --bg-main: #f5f5f7;
    --card-white: #ffffff;
    --text-dark: #1d1d1f;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg-main);
    color: var(--text-dark);
    padding: 20px;
    margin: 0;
    display: flex;
    justify-content: center;
}

.box { width: 100%; max-width: 440px; }

.card {
    background: var(--card-white);
    padding: 25px;
    border-radius: 24px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.05);
    margin-bottom: 20px;
    border: 1px solid #e5e5e7;
}

h2 {
    text-align: center;
    font-weight: 600;
    margin-bottom: 25px;
}

label {
    display: block;
    font-size: 13px;
    color: #86868b;
    margin-bottom: 8px;
    font-weight: 500;
    padding-left: 4px;
}

select, input {
    width: 100%;
    padding: 14px;
    background: #fafafa;
    border: 1px solid #d2d2d7;
    border-radius: 12px;
    font-size: 16px;
    margin-bottom: 18px;
    box-sizing: border-box;
}

select:focus, input:focus {
    border-color: var(--apple-blue);
    outline: none;
}

#go {
    width: 100%;
    padding: 18px;
    background: var(--apple-blue);
    color: #fff;
    border: none;
    border-radius: 16px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
}

#res {
    display: none;
    margin-top: 25px;
    background: #fff;
    border-radius: 24px;
    padding: 25px;
    border: 1px solid #e5e5e7;
    animation: slideUp 0.4s ease-out;
}

@keyframes slideUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
}

.finance-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 15px;
    font-size: 12px;
}

.finance-table th {
    background: #fbfbfd;
    padding: 12px 5px;
    color: #86868b;
    font-weight: 500;
    border-bottom: 1px solid #eee;
}

.finance-table td {
    padding: 14px 5px;
    text-align: center;
    border-bottom: 1px solid #f5f5f7;
}

.model-name {
    font-weight: 700;
    text-align: left !important;
    padding-left: 10px !important;
}

.price-tag {
    color: #d70015;
    font-weight: 600;
}

.daily-blue {
    color: var(--apple-blue);
    font-weight: 800;
    font-size: 15px;
}

#ai-output {
    font-size: 15px;
    line-height: 1.8;
    color: #3a3a3c;
    border-top: 1px solid #f2f2f2;
    padding-top: 20px;
}

.quote {
    font-style: italic;
    color: var(--apple-blue);
    font-weight: 600;
    margin-top: 18px;
    display: block;
    text-align: center;
    font-size: 13px;
}

.admin-section {
    margin-top: 40px;
    padding: 15px;
    border-top: 2px dashed #d2d2d7;
}

#apiKey { font-size: 10px; }
</style>
</head>

<body>
<div class="box">

<h2>舊換新回收建議（內部使用）</h2>

<div class="card">
<label>鑑定舊機型號</label>
<select id="m">
<option>iPhone 16 Pro Max</option>
<option>iPhone 16 Pro</option>
<option>iPhone 16 Plus</option>
<option>iPhone 16</option>
<option>iPhone 15 Pro Max</option>
<option>iPhone 15 Pro</option>
<option>iPhone 15 Plus</option>
<option>iPhone 15</option>
<option>iPhone 14 Pro Max</option>
<option>iPhone 14 Pro</option>
<option>iPhone 14 Plus</option>
<option>iPhone 14</option>
<option>iPhone 13 Pro Max</option>
<option>iPhone 13 Pro</option>
<option>iPhone 13</option>
<option>iPhone 13 mini</option>
<option>iPhone 12 Pro Max</option>
<option>iPhone 12 Pro</option>
<option>iPhone 12</option>
<option>iPhone 12 mini</option>
<option>iPhone 11 Pro Max</option>
<option>iPhone 11 Pro</option>
<option>iPhone 11</option>
</select>

<label>外觀狀態</label>
<select id="cond">
<option>外觀完美</option>
<option>輕微使用痕跡</option>
<option>明顯傷痕</option>
<option>螢幕或背蓋損壞</option>
</select>

<div style="display:flex; gap:12px;">
<div style="flex:1">
<label>電池健康度 %</label>
<input type="number" id="ba" value="85">
</div>
<div style="flex:1">
<label>舊機回收價 (NT$)</label>
<input type="number" id="pr">
</div>
</div>

<button id="go" onclick="runCheck()">開始分析</button>
</div>

<div id="res">
<table class="finance-table">
<thead>
<tr>
<th style="text-align:left;padding-left:10px;">目標新機</th>
<th>參考價</th>
<th>需補差價</th>
<th>每月 / 每日</th>
</tr>
</thead>
<tbody id="financeBody"></tbody>
</table>

<div style="font-size:11px;color:#999;text-align:center;margin-bottom:10px;">
※ 價格以實際上市公告為準
</div>

<div id="ai-output"></div>
<span class="quote">「使用，才真正賦予價值」</span>
</div>

<div class="admin-section">
<label>系統設定（僅需設定一次）</label>
<input type="password" id="apiKey" oninput="saveKey()" placeholder="gsk_ 開頭金鑰">
</div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const savedKey = localStorage.getItem('my_groq_key');
    if (savedKey) {
        document.getElementById('apiKey').value = savedKey;
        document.querySelector('.admin-section').style.display = 'none';
    }
});

function saveKey() {
    const key = document.getElementById('apiKey').value.trim();
    if (key.startsWith('gsk_')) {
        localStorage.setItem('my_groq_key', key);
        document.querySelector('.admin-section').style.display = 'none';
    }
}

async function runCheck() {
    const key = localStorage.getItem('my_groq_key');
    const tradeIn = parseFloat(document.getElementById('pr').value);
    const model = document.getElementById('m').value;
    const cond = document.getElementById('cond').value;
    const battery = parseInt(document.getElementById('ba').value);

    if (!tradeIn || !key) {
        alert("請輸入回收價並完成金鑰設定");
        return;
    }

    let batteryNote = "";
    if (battery < 80) batteryNote = "（電池已明顯老化）";
    else if (battery < 85) batteryNote = "（電池續航開始下滑）";

    const models = [
        { name: "iPhone 17", price: 29900 },
        { name: "iPhone 17 Pro", price: 39900 },
        { name: "iPhone 17 Pro Max", price: 44900 }
    ];

    const tbody = document.getElementById('financeBody');
    tbody.innerHTML = "";

    models.forEach(m => {
        const gap = m.price - tradeIn;
        const monthly = Math.round(gap / 12);
        const daily = Math.round(gap / 365);

        tbody.innerHTML += `
        <tr>
            <td class="model-name">${m.name}</td>
            <td>$${m.price.toLocaleString()}</td>
            <td class="price-tag">$${gap.toLocaleString()}</td>
            <td>$${monthly} / <span class="daily-blue">$${daily}</span></td>
        </tr>`;
    });

    document.getElementById('res').style.display = "block";
    document.getElementById('ai-output').innerText = "分析中…";

    const prompt = `
你是專業資產顧問。客戶持有 ${model}，外觀狀況為 ${cond}，
電池健康度 ${battery}%${batteryNote}，目前回收價為 ${tradeIn} 元。

請運用以下觀念說明：
1. 閒置即虧損：未使用的舊手機只會隨時間貶值。
2. 價值活化：回收是將舊資產轉化為新設備的資金。
3. 費用感官：用每日成本理解升級壓力。
4. 備用機迷思：久放易壞，並非真正保值。
5. 給家人的迷思：效能與電池不佳的舊機，往往是負擔。

請用 180 字內、專業誠懇的繁體中文回答，強調「使用才賦予價值」。
結尾請不要替顧客決定購買哪一款，而是用適合族群的方式說明：

- iPhone 17：適合希望以最低成本完成換機、重視止血效果的人。
- iPhone 17 Pro：適合在意效能、使用年限與價格平衡的人。
- iPhone 17 Pro Max：適合預算較寬鬆、注重拍攝、想拉長換機週期的人。

最後請加一句中性引導語，讓顧客自行對照哪一種描述最符合自己。
`;

    try {
        const response = await fetch("https://api.groq.com/openai/v1/chat/completions", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Authorization": "Bearer " + key
            },
            body: JSON.stringify({
                model: "llama-3.3-70b-versatile",
                messages: [{ role: "user", content: prompt }]
            })
        });

        const data = await response.json();
        document.getElementById('ai-output').innerText =
            data.choices[0].message.content;
    } catch {
        document.getElementById('ai-output').innerText = "系統連線異常";
    }
}
</script>

</body>
</html>

