# LINE Bot
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Firebase
FIREBASE_API_KEY=AIzaSy...
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# Claude API（用於 /claude-proxy 圖片分析）
CLAUDE_API_KEY=sk-ant-...

# 管理員設定
# ADMIN_USER_ID：你的 LINE userId，用於廣播功能（輸入「廣播 訊息內容」）
# 取得方式：加入 Bot 後傳任意訊息，查看伺服器 log 中的 userId
ADMIN_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 手動觸發推播的驗證密碼（POST /price-check 的 x-admin-secret header）
# 可自訂任意字串，留空則不需要驗證
ADMIN_SECRET=your_secret_here

# Server
PORT=3000
